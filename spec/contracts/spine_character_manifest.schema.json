{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "spine_character_manifest.schema.json",
  "title": "Spine Character Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "presentationId",
    "skeletonFile",
    "atlasFile",
    "texturePages",
    "animations",
    "slots",
    "anchorProfile",
    "scaleProfile",
    "defaultVariantId",
    "variants"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "spine_character_manifest_v2"
    },
    "presentationId": { "type": "string" },
    "skeletonFile": { "type": "string" },
    "atlasFile": { "type": "string" },
    "texturePages": {
      "type": "array",
      "items": { "type": "string" }
    },
    "animations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "slots": {
      "type": "array",
      "items": { "type": "string" }
    },
    "anchorProfile": {
      "type": "object",
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "scaleProfile": {
      "type": "object",
      "required": ["baseScale"],
      "properties": {
        "baseScale": { "type": "number" }
      }
    },
    "defaultVariantId": { "type": "string" },
    "variants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/variant"
      }
    }
  },
  "$defs": {
    "variant": {
      "type": "object",
      "required": [
        "variantId",
        "label",
        "skin",
        "enabled",
        "allowedAnimations",
        "resourceOverrides"
      ],
      "properties": {
        "variantId": { "type": "string" },
        "label": { "type": "string" },
        "skin": { "type": "string" },
        "enabled": { "type": "boolean" },
        "allowedAnimations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requiredComponents": {
          "type": "array",
          "items": { "type": "string" }
        },
        "anchorProfileOverride": {
          "type": ["object", "null"]
        },
        "scaleProfileOverride": {
          "type": ["object", "null"]
        },
        "resourceOverrides": {
          "type": "object"
        },
        "notes": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
