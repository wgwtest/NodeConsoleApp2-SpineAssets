{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "character_request.schema.json",
  "title": "Character Request",
  "type": "object",
  "required": [
    "schemaVersion",
    "characterRequestId",
    "presentationId",
    "title",
    "description",
    "bundleTarget",
    "variants",
    "requiredActions",
    "requiredSlots"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "character_request_v1"
    },
    "characterRequestId": { "type": "string" },
    "presentationId": { "type": "string" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "bundleTarget": { "type": "string" },
    "variants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/variantRequest"
      }
    },
    "requiredActions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requiredSlots": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "variantRequest": {
      "type": "object",
      "required": ["variantId", "label", "skin"],
      "properties": {
        "variantId": { "type": "string" },
        "label": { "type": "string" },
        "skin": { "type": "string" }
      }
    }
  }
}
