{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "spine_bundle_manifest.schema.json",
  "title": "Spine Bundle Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "bundleId",
    "bundleVersion",
    "generatedAt",
    "sourceCatalog",
    "characters"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "bundleId": { "type": "string" },
    "bundleVersion": { "type": "string" },
    "generatedAt": { "type": "string" },
    "sourceCatalog": {
      "type": "object",
      "required": ["schemaVersion", "generatedAt"],
      "properties": {
        "schemaVersion": { "type": "string" },
        "generatedAt": { "type": "string" }
      }
    },
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["presentationId", "characterManifest"],
        "properties": {
          "presentationId": { "type": "string" },
          "characterManifest": { "type": "string" }
        }
      }
    }
  }
}
